# ==========================================
# Configurações de Conexão - OpenSearch
# ==========================================
# Insira os IPs ou Hostnames dos seus nós OpenSearch separados por vírgula
OPENSEARCH_HOSTS=10.0.0.10,10.0.0.11 ou server-name
OPENSEARCH_USER=admin
OPENSEARCH_PASS=senha_super_secreta

# Caminhos absolutos para os certificados SSL/TLS da sua infraestrutura
OPENSEARCH_CA_CERT=/opt/staging/certs/ca-certificate.pem
OPENSEARCH_CLIENT_CERT=/opt/staging/certs/client-cert.crt
OPENSEARCH_CLIENT_KEY=/opt/staging/certs/client-cert.key

# ==========================================
# Configurações de Conexão - S3 Local (MinIO / Ceph)
# ==========================================
AWS_ACCESS_KEY_ID=sua_access_key_local_aqui
AWS_SECRET_ACCESS_KEY=sua_secret_key_local_aqui

# URL exata do seu servidor S3 On-Premise (incluindo http/https e porta)
S3_ENDPOINT_URL=http://10.0.0.50
# Para S3 compatível local, geralmente mantém-se us-east-1 para a biblioteca boto3 funcionar bem
S3_REGION=us-east-1
S3_BUCKET_NAME=graylog-cold-storage

# ==========================================
# Configurações do Graylog e do Script
# ==========================================
# ID do Stream no Graylog onde os logs de auditoria do backup serão salvos
GRAYLOG_STREAM_ID=68efd101XXXXXXXXXXXXX

# Diretório temporário na VM onde o script fará a extração e compressão antes do upload
STAGING_DIR=/opt/staging

# Quantidade de threads simultâneas usadas no processo de backup
MAX_BACKUP_WORKERS=4
